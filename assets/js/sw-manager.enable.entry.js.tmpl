import { createServiceWorkerManagerRuntime } from './sw-manager.enable.runtime.js';
import { startEnableMode } from './sw-manager.enable.update.js';

const runtime = createServiceWorkerManagerRuntime({
    swUrl: {{ printf "%q" .sw_url }},
    swScope: '/',
    updateCheckInterval: {{ mul .check_interval 60000 }},
    updateVisibilityThrottle: {{ mul .visibility_throttle 60000 }}
});

startEnableMode(runtime);
