{{- $lang := .Language.Lang -}}
{{- $path := "" -}}
{{- $format := "" -}}
{{- $bases := slice "i18n" "themes/banyan/i18n" -}}
{{- $formats := slice "toml" "yaml" "yml" "json" -}}
{{- range $base := $bases -}}
  {{- range $ext := $formats -}}
    {{- if not $path -}}
      {{- $candidate := printf "%s/%s.%s" $base $lang $ext -}}
      {{- if fileExists $candidate -}}
        {{- $path = $candidate -}}
        {{- $format = $ext -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
{{- end -}}

{{- $translations := dict -}}
{{- if $path -}}
  {{- $translations = transform.Unmarshal (dict "format" $format) (readFile $path) -}}
{{- end -}}

{{- $noTrans := "This page is not available in [{lang}].\nRedirect to the homepage?" -}}
{{- with index $translations "no_trans_msg" -}}
  {{- with index . "other" -}}
    {{- $noTrans = printf "%v" . -}}
  {{- end -}}
{{- end -}}

{{- $langSuggest := "We recommend the [{target}] version of this page.\nContinue?" -}}
{{- with index $translations "lang_suggest_msg" -}}
  {{- with index . "other" -}}
    {{- $langSuggest = printf "%v" . -}}
  {{- end -}}
{{- end -}}

{{- $siteUpdatePrompt := "A new version is ready. Refresh now?" -}}
{{- with index $translations "site_update_prompt" -}}
  {{- with index . "other" -}}
    {{- $siteUpdatePrompt = printf "%v" . -}}
  {{- end -}}
{{- end -}}

{{- $siteUpdateConfirm := "Refresh" -}}
{{- with index $translations "site_update_confirm" -}}
  {{- with index . "other" -}}
    {{- $siteUpdateConfirm = printf "%v" . -}}
  {{- end -}}
{{- end -}}

{{- $siteUpdateLater := "Later" -}}
{{- with index $translations "site_update_later" -}}
  {{- with index . "other" -}}
    {{- $siteUpdateLater = printf "%v" . -}}
  {{- end -}}
{{- end -}}

{{- $siteVersionLabelDefaults := dict
  "check" "Check now"
  "checking" "Checking..."
  "check_failed" "Check failed"
  "status" "Status"
  "status_current" "Up to date"
  "status_ready" "New version available"
  "status_offline" "Offline"
  "status_click_update" "click update"
  "status_click_retry" "click retry"
-}}
{{- $siteVersionLabels := $siteVersionLabelDefaults -}}
{{- $siteVersionChangelogHref := "" -}}
{{- with .GetPage "/fragments/nav-utilities" -}}
  {{- $navConfig := .Params.nav | default dict -}}
  {{- $versionConfig := index $navConfig "version" | default dict -}}
  {{- $siteVersionLabels = merge $siteVersionLabelDefaults (index $versionConfig "labels" | default dict) -}}
  {{- $siteVersionChangelogHref = trim (printf "%v" (index $versionConfig "changelog_href" | default "")) " \r\n\t" -}}
  {{- if and $siteVersionChangelogHref (hasPrefix $siteVersionChangelogHref "/") -}}
    {{- $siteVersionChangelogHref = $siteVersionChangelogHref | relLangURL -}}
  {{- end -}}
{{- end -}}

{{- dict
  "no_trans_msg" $noTrans
  "lang_suggest_msg" $langSuggest
  "site_update_prompt" $siteUpdatePrompt
  "site_update_confirm" $siteUpdateConfirm
  "site_update_later" $siteUpdateLater
  "site_version_check" (printf "%v" (index $siteVersionLabels "check"))
  "site_version_checking" (printf "%v" (index $siteVersionLabels "checking"))
  "site_version_check_failed" (printf "%v" (index $siteVersionLabels "check_failed"))
  "site_version_status" (printf "%v" (index $siteVersionLabels "status"))
  "site_version_status_current" (printf "%v" (index $siteVersionLabels "status_current"))
  "site_version_status_ready" (printf "%v" (index $siteVersionLabels "status_ready"))
  "site_version_status_offline" (printf "%v" (index $siteVersionLabels "status_offline"))
  "site_version_status_click_update" (printf "%v" (index $siteVersionLabels "status_click_update"))
  "site_version_status_click_retry" (printf "%v" (index $siteVersionLabels "status_click_retry"))
  "site_version_changelog_href" $siteVersionChangelogHref
| jsonify -}}
